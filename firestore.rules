rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── User document ───────────────────────────────────────────────────────
    // Vetëm pronari i llogarisë mund të lexojë/shkruajë dokumentin e vet.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // ── Child profiles ────────────────────────────────────────────────────
      match /children/{childId} {
        allow read, write: if isOwner(uid);

        // ── Progress subcollection ────────────────────────────────────────
        match /progress/{progressId} {
          allow read, write: if isOwner(uid);
        }

        // ── Daily stats subcollection (Sprint 12) ─────────────────────────
        // Vetëm prindi (uid) mund të lexojë dhe shkruajë statistikat
        // e fëmijës së vet. Asnjë përdorues tjetër nuk ka akses.
        match /daily_stats/{date} {
          allow read: if isOwner(uid);
          allow write: if isOwner(uid);
        }
      }
    }

  }
}
