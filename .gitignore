# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS Files
*.log

# Android Studio generated files and folders
captures/
.externalNativeBuild/
.cxx/
*.aab
*.apk
output-metadata.json

# Flutter tools
.dart_tool/
.flutter-plugins-dependencies
.dart_tool/extension_discovery/vs_code.json

# Android signing credentials (never commit)
android/key.properties

# Firebase config — të sigurta për commit (sigurisë i vendoset via Firebase Rules)
# lib/firebase_options.dart  ← committed
# android/app/google-services.json  ← committed
ios/Runner/GoogleService-Info.plist

# IntelliJ
*.iml
.idea/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Keystore files
*.jks
*.keystore

# Google Services — i sigurt për commit (nuk ka sekrete, siguria është via Firebase Rules)
# google-services.json  ← committed

# Android Profiling
*.hprof
